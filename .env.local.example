# Ampliphi read-replica Postgres
# Copy to .env.local (gitignored) and fill in real values.
AMPLIPHI_DB_URL=postgres://USER:PASSWORD@HOST:5432/DBNAME?sslmode=require

# Default hotel that loads on first visit if no scope is selected
DEFAULT_HOTEL_ID=AI3786

# Connection pool tuning (optional)
AMPLIPHI_DB_POOL_MAX=5
AMPLIPHI_DB_IDLE_MS=30000
AMPLIPHI_DB_QUERY_TIMEOUT_MS=15000

# In-memory cache TTL for query results (milliseconds)
AMPLIPHI_QUERY_CACHE_TTL_MS=300000
